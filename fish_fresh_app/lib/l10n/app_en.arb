  "kapentaName": "Kapenta",
  "kapentaHabitat": "Lakes Tanganyika & Kariba",
  "kapentaSeason": "Year-round",
  "kapentaPriceRange": "ZMW 20–60/kg (fresh) · ZMW 80–150/kg (dried)",
  "kapentaDescription": "Tiny freshwater sardines — the most commercially important fish in Zambia. Sold fresh or sun-dried. Dried kapenta is a staple across all provinces.",
  "kapentaFreshIndicators": "Fresh kapenta: silver sheen, clear eyes, mild sea smell. Dried kapenta: uniform light-brown colour, dry to touch, no mould, mild smell.",
  "kapentaSpoilageWarning": "Yellowish colour, strong fishy odour, or stickiness on fresh kapenta means it is no longer safe. Dried kapenta with dark patches or visible mould should be discarded.",
  "kapentaCookingTip": "Best fried crispy with onions and tomatoes, or simmered in groundnut relish (nshima accompaniment).",

  "breamName": "Bream (Tilapia)",
  "breamHabitat": "Most freshwater bodies",
  "breamSeason": "Year-round",
  "breamPriceRange": "ZMW 35–100/kg",
  "breamDescription": "The most widely consumed fish in Zambia. Found in rivers, dams and lakes nationwide. Available in nearly every market, often sold live.",
  "breamFreshIndicators": "Bright red or deep pink gills, clear bulging eyes, firm flesh that springs back when pressed, shiny silver-green skin with tight scales.",
  "breamSpoilageWarning": "Brown or grey gills, sunken or cloudy eyes, soft mushy flesh, and strong sour smell are all clear signs of deterioration.",
  "breamCookingTip": "Excellent grilled whole with tomatoes and onions, or fried. Commonly used in Zambian relish.",

  "tigerName": "Tiger fish",
  "tigerHabitat": "Zambezi River, Lake Kariba",
  "tigerSeason": "Best Aug–Oct",
  "tigerPriceRange": "ZMW 60–140/kg",
  "tigerDescription": "Fierce predatory fish from the Zambezi and Lake Kariba. Prized for its firm, white flesh. Popular with sport anglers and a delicacy at markets near Kariba.",
  "tigerFreshIndicators": "Distinctive silver body with black tiger stripes. Bright eyes, firm white flesh, and a mild fresh smell. Teeth remain prominent and jaw is well-defined.",
  "tigerSpoilageWarning": "Fading stripes, dull discoloured skin, loose scales and a strong ammonia-like smell indicate the fish is past its best.",
  "tigerCookingTip": "Best grilled or baked whole with lemon and herbs. The firm flesh holds well on a braai.",

  "mpumbuName": "Mpumbu",
  "mpumbuHabitat": "Lake Bangweulu",
  "mpumbuSeason": "Jun–Oct",
  "mpumbuPriceRange": "ZMW 50–120/kg",
  "mpumbuDescription": "A prized, large lake fish endemic to Lake Bangweulu. Highly valued by local communities and often dried or smoked. Scarcity makes it relatively expensive.",
  "mpumbuFreshIndicators": "Deep silver body with prominent scales. Clear eyes, bright red-pink gills, and firm iridescent flesh. Fresh specimens have almost no smell.",
  "mpumbuSpoilageWarning": "Any discolouration of the flesh from white to yellowish, combined with a sour or strong fishy odour, indicates spoilage.",
  "mpumbuCookingTip": "Wonderful smoked or grilled. The flavour is rich — pairs well with simple seasoning to let the fish shine.",

  "chessaName": "Chessa",
  "chessaHabitat": "Lakes Bangweulu & Mweru",
  "chessaSeason": "Year-round",
  "chessaPriceRange": "ZMW 25–70/kg",
  "chessaDescription": "A medium-sized lake fish common in Lake Bangweulu and Lake Mweru. Often sold dried in bulk. An important protein source in Northern and Luapula provinces.",
  "chessaFreshIndicators": "Silvery skin with firm texture. Clear eyes and tight intact scales. Fresh smell with no sourness. Dried chessa should be golden-brown and dry throughout.",
  "chessaSpoilageWarning": "Soft spots on the flesh, visible slime on the skin, cloudy eyes, or an ammonia-like odour are all signs to avoid.",
  "chessaCookingTip": "Usually fried or dried and powdered as a flavouring. Works well in stews and nshima relish.",

  "vunduName": "Vundu (Catfish)",
  "vunduHabitat": "Zambezi River & major rivers",
  "vunduSeason": "Year-round",
  "vunduPriceRange": "ZMW 40–100/kg",
  "vunduDescription": "Large freshwater catfish found in the Zambezi and Kafue rivers. Can grow very large — up to 50kg. Has no scales. Excellent firm white flesh, popular for smoking.",
  "vunduFreshIndicators": "Moist, slightly slimy skin (normal for catfish). Firm pale flesh, clear eyes, and mild fresh smell with no sourness.",
  "vunduSpoilageWarning": "Excessive stickiness, yellowing of the flesh, strong ammonia smell, or visibly soft flesh are warning signs.",
  "vunduCookingTip": "Superb smoked, grilled in large cuts, or curried. The thick flesh is very forgiving to cook."
